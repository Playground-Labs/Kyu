{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kyu",
  "version": "0.1.0",
  "identifier": "dev.kyu.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Kyu",
        "width": 760,
        "height": 560,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "createUpdaterArtifacts": false
  }
}
