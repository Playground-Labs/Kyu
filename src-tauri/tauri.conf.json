{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kyu",
  "version": "0.2.1",
  "identifier": "dev.kyu",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Kyu",
        "width": 768,
        "height": 112,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "DeveloperTool",
    "createUpdaterArtifacts": false,
    "icon": ["icons/icon.icns"]
  }
}
